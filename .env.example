# =========================
# Site / Auth
# =========================
AUTH_SECRET=your-auth-secret-generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=1
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# Public provider list controls which buttons appear on /login.
# Use credentials only after configuring AUTH_PASSWORD_EMAIL + AUTH_PASSWORD_HASH below.
NEXT_PUBLIC_AUTH_PROVIDERS=credentials,github,google
AUTH_REGISTRATION_ENABLED=true
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=true

# Site password login (optional, useful before OAuth is configured)
# Generate the hash with:
# npm run auth:hash-password -- "a-long-private-password"
AUTH_PASSWORD_EMAIL=you@example.com
AUTH_PASSWORD_NAME=Evan
AUTH_PASSWORD_ROLE=admin
AUTH_PASSWORD_HASH=pbkdf2$v1$sha256$310000$replace_salt$replace_hash
# For multiple site accounts, use JSON instead of the single-user fields:
# AUTH_PASSWORD_USERS_JSON='[{"email":"you@example.com","name":"Evan","role":"admin","passwordHash":"pbkdf2$v1$sha256$310000$..."}]'

# OAuth Providers (optional)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =========================
# Firebase Admin (used by Auth adapter + membership/attempt persistence)
# =========================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# =========================
# Stripe Billing (subscription membership)
# =========================
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_MEMBER_MONTHLY=price_xxx
# Optional if yearly billing is enabled; can be left empty if not used.
STRIPE_PRICE_ID_MEMBER_YEARLY=price_xxx
# Enable premium gating only after Stripe/admin configuration has been verified.
NOTES_MEMBERSHIP_GATING=false
NEXT_PUBLIC_NOTES_MEMBERSHIP_GATING=false

# Production base URL used in checkout/portal callbacks.
APP_URL=https://your-domain.com

# Server-side admin whitelist (comma-separated emails)
ADMIN_EMAILS=you@example.com,second@example.com

# =========================
# Optional TinaCMS
# =========================
TINA_CLIENT_ID=your-tina-client-id
NEXT_PUBLIC_TINA_CLIENT_ID=your-tina-client-id
TINA_TOKEN=your-tina-token
