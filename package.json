{
  "name": "personal-site-template",
  "version": "1.0.0",
  "private": true,
  "description": "A modern personal website template with glass morphism design, MDX blog, and private diary",
  "author": "Your Name",
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:site",
    "start": "next start",
    "lint": "eslint",
    "contentlayer": "contentlayer2 build",
    "build:site": "contentlayer2 build && next build --webpack",
    "build:cms": "npm run tina:build:auto && contentlayer2 build && next build --webpack",
    "tina:build": "tinacms build",
    "tina:build:auto": "if [ -n \"$TINA_TOKEN\" ] && [ -n \"${NEXT_PUBLIC_TINA_CLIENT_ID:-$TINA_CLIENT_ID}\" ]; then tinacms build; else tinacms build --local --skip-cloud-checks --skip-search-index; fi",
    "tina:dev": "tinacms dev -c 'next dev'",
    "check:textbook-content": "node scripts/check-textbook-content.mjs"
    "storyboard:generate": "node tools/storyboard/generate-storyboards.mjs",
    "storyboard:pilot-evaluate": "node tools/storyboard/evaluate-pilot.mjs"
  },
  "dependencies": {
    "@auth/firebase-adapter": "^2.11.1",
    "@next/mdx": "^16.1.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-pdf/renderer": "^4.3.2",
    "@simplewebauthn/server": "^13.0.0",
    "@tinacms/cli": "^2.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.0.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "19.2.3",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.4.0",
    "tinacms": "^2.10.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "yaml": "^2.8.1"
  }
}
