# Copy this file to .env.codex-account.preview.local and fill real
# development/staging values. Do not commit the .local file.

# Branch-scoped public surface.
SITE_SURFACE=preview
NEXT_PUBLIC_SITE_SURFACE=preview
NEXT_PUBLIC_SITE_URL=https://development.evanalysis.top
APP_URL=https://development.evanalysis.top
NEXTAUTH_URL=https://development.evanalysis.top
AUTH_TRUST_HOST=1

# Auth.js session secret for the codex/account preview branch.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-preview-auth-secret

# Public login and registration.
NEXT_PUBLIC_AUTH_PROVIDERS=credentials,github,google
AUTH_REGISTRATION_ENABLED=true
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=true
AUTH_REGISTRATION_REQUIRE_TURNSTILE=true
NEXT_PUBLIC_AUTH_REGISTRATION_REQUIRE_TURNSTILE=true
AUTH_REGISTRATION_REQUIRE_PERSISTENCE=true

# Cloudflare Turnstile widget for development.evanalysis.top.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
AUTH_TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# Development/staging Firebase Admin SDK. Do not reuse production.
FIREBASE_PROJECT_ID=replace-with-staging-firebase-project-id
FIREBASE_CLIENT_EMAIL=replace-with-staging-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-staging-private-key\n-----END PRIVATE KEY-----\n"

# Development OAuth apps. Remove github/google from NEXT_PUBLIC_AUTH_PROVIDERS
# if either provider is not ready yet.
GITHUB_CLIENT_ID=replace-with-github-development-client-id
GITHUB_CLIENT_SECRET=replace-with-github-development-client-secret
GOOGLE_CLIENT_ID=replace-with-google-development-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-development-client-secret

# Stripe test mode for development checkout QA.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace
# Optional branch overrides. Leave omitted if preview/project-level test vars
# are already configured correctly.
# STRIPE_SECRET_KEY=sk_test_replace
# STRIPE_WEBHOOK_SECRET=whsec_replace
# STRIPE_PRICE_ID_MEMBER_MONTHLY=price_replace
# STRIPE_PRICE_ID_MEMBER_YEARLY=price_replace
# NOTES_MEMBERSHIP_GATING=true
# NEXT_PUBLIC_NOTES_MEMBERSHIP_GATING=true
